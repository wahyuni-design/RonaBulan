<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/bg_header_curved">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="36dp"
                android:background="@drawable/bg_circle_pink_light"
                android:src="@android:drawable/ic_media_previous"
                android:contentDescription="Kembali"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_centerInParent="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128302;"
                    android:textSize="32sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detail dan Prediksi"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Cycle Phase Progress Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fase Siklus Saat Ini"
                        android:textColor="@color/text_medium"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05"
                        android:layout_marginBottom="16dp"/>

                    <!-- 4 Phase Indicators -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Menstruasi -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_card_pink_gradient">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&#129656;"
                                    android:textSize="22sp"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mens"
                                android:textColor="@color/pink_600"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1-5"
                                android:textColor="@color/text_light"
                                android:textSize="9sp"/>
                        </LinearLayout>

                        <!-- Arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8594;"
                            android:textColor="@color/pink_300"
                            android:textSize="16sp"/>

                        <!-- Folikuler -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_circle_pink_light">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&#127807;"
                                    android:textSize="22sp"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Folikuler"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="6-13"
                                android:textColor="@color/text_light"
                                android:textSize="9sp"/>
                        </LinearLayout>

                        <!-- Arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8594;"
                            android:textColor="@color/pink_300"
                            android:textSize="16sp"/>

                        <!-- Ovulasi -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_circle_pink_light">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&#127765;"
                                    android:textSize="22sp"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ovulasi"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hari 14"
                                android:textColor="@color/text_light"
                                android:textSize="9sp"/>
                        </LinearLayout>

                        <!-- Arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#8594;"
                            android:textColor="@color/pink_300"
                            android:textSize="16sp"/>

                        <!-- Luteal -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:background="@drawable/bg_circle_pink_light">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="&#127766;"
                                    android:textSize="22sp"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Luteal"
                                android:textColor="@color/text_medium"
                                android:textSize="10sp"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginTop="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15-28"
                                android:textColor="@color/text_light"
                                android:textSize="9sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#FFF0F5"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tv_current_phase_desc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Kamu sedang berada di Hari 14 - masa ovulasi. Ini adalah puncak kesuburan dalam siklusmu."
                        android:textColor="@color/text_medium"
                        android:textSize="13sp"
                        android:lineSpacingExtra="3dp"
                        android:background="@drawable/bg_card_white"
                        android:padding="12dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Prediction Cards label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prediksi Mendatang"
                android:textColor="@color/text_medium"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <!-- Next Period -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_card_pink_gradient">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#129656;"
                            android:textSize="28sp"
                            android:layout_gravity="center"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Haid Berikutnya"
                            android:textColor="@color/text_light"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_next_period_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="11 Mei 2026"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_days_until_period"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14"
                            android:textColor="@color/pink_600"
                            android:textSize="28sp"
                            android:fontFamily="sans-serif-bold"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="hari lagi"
                            android:textColor="@color/text_light"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Fertile Window -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_circle_pink_filled">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#127807;"
                            android:textSize="28sp"
                            android:layout_gravity="center"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jendela Subur"
                            android:textColor="@color/text_light"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_fertile_window"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24 Apr - 28 Apr"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kemungkinan hamil tinggi"
                            android:textColor="@color/text_light"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Ovulation Day -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_circle_pink_filled">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#127765;"
                            android:textSize="28sp"
                            android:layout_gravity="center"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hari Ovulasi"
                            android:textColor="@color/text_light"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/tv_ovulation_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="27 April 2026"
                            android:textColor="@color/text_dark"
                            android:textSize="18sp"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Perkiraan hari ini"
                            android:textColor="@color/pink_600"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Insight Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insight Siklus"
                android:textColor="@color/text_medium"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFF0F5">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tv_insight_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Siklusmu tergolong reguler (26-30 hari)"
                        android:textColor="@color/text_medium"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_insight_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Durasi haid konsisten sekitar 5 hari"
                        android:textColor="@color/text_medium"
                        android:textSize="13sp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/tv_insight_3"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Jika ada perubahan signifikan, konsultasikan ke dokter"
                        android:textColor="@color/text_medium"
                        android:textSize="13sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
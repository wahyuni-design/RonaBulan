<resources>
    <style name="Theme.RonaBulan" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/pink_600</item>
        <item name="colorPrimaryVariant">@color/pink_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/blush</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="android:colorBackground">@color/white_soft</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="android:windowBackground">@color/white_soft</item>
        <item name="android:statusBarColor">@color/pink_600</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>
    <style name="Theme.RonaBulan.Splash" parent="Theme.RonaBulan">
        <item name="android:statusBarColor">@color/pink_600</item>
        <item name="android:windowBackground">@color/pink_600</item>
    </style>
    <style name="RonaBulan.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPaddingLeft">16dp</item>
        <item name="contentPaddingRight">16dp</item>
        <item name="contentPaddingTop">16dp</item>
        <item name="contentPaddingBottom">16dp</item>
    </style>
    <style name="RonaBulan.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/pink_600</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="elevation">6dp</item>
    </style>
    <!--  Button Secondary (Outlined)  -->
    <style name="RonaBulan.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/pink_500</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:textColor">@color/pink_600</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="RonaBulan.Text" parent="android:Widget.TextView">
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
    </style>
    <style name="RonaBulan.Text.Title">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>
    <style name="RonaBulan.Text.Subtitle">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_light</item>
    </style>
    <style name="RonaBulan.Text.SectionHeader">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_medium</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
    <style name="RonaBulan.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/pink_100</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipStrokeColor">@color/pink_300</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textColor">@color/pink_600</item>
        <item name="chipCornerRadius">50dp</item>
    </style>
    <style name="RonaBulan.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/pink_300</item>
        <item name="hintTextColor">@color/pink_500</item>
        <item name="boxBackgroundColor">@color/white</item>
    </style>
</resources>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <gradient android:angle="135" android:startColor="#FFD6E7" android:endColor="#FFB3D1" android:type="linear"/>
            <corners android:radius="20dp"/>
            <stroke android:width="2dp" android:color="#E84D8A"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <corners android:radius="20dp"/>
            <stroke android:width="1dp" android:color="#FFD6E7"/>
        </shape>
    </item>
</selector>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/gradient_bg" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <!--  Header  -->
        <RelativeLayout android:layout_width="match_parent" android:layout_height="160dp" android:background="@drawable/bg_header_curved">
            <ImageButton android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="16dp" android:layout_marginTop="36dp" android:background="@drawable/bg_circle_pink_light" android:src="@android:drawable/ic_media_previous" android:contentDescription="Kembali"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_centerInParent="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💭" android:textSize="36sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mood Tracker" android:textColor="#FFFFFF" android:textSize="22sp" android:fontFamily="serif" android:textStyle="bold" android:layout_marginTop="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bagaimana perasaanmu hari ini?" android:textColor="#FFDDF0" android:textSize="13sp" android:fontFamily="sans-serif-light" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </RelativeLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
            <!--  Main Mood Selector Card  -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="24dp" app:cardElevation="6dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pilih Mood Utama" android:textColor="@color/text_medium" android:textSize="14sp" android:fontFamily="sans-serif-medium" android:letterSpacing="0.05" android:layout_marginBottom="16dp"/>
                    <!--  Mood Grid - Row 1  -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <!--  Happy  -->
                        <LinearLayout android:id="@+id/mood_happy" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginEnd="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bahagia" android:textColor="@color/text_dark" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!--  Sad  -->
                        <LinearLayout android:id="@+id/mood_sad" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginStart="5dp" android:layout_marginEnd="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😢" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sedih" android:textColor="@color/text_dark" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!--  Angry  -->
                        <LinearLayout android:id="@+id/mood_angry" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginStart="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😤" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Marah" android:textColor="@color/text_dark" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <!--  Mood Grid - Row 2  -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="10dp">
                        <!--  Anxious  -->
                        <LinearLayout android:id="@+id/mood_anxious" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginEnd="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😰" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cemas" android:textColor="@color/text_dark" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!--  Calm  -->
                        <LinearLayout android:id="@+id/mood_calm" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginStart="5dp" android:layout_marginEnd="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😌" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tenang" android:textColor="@color/text_dark" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!--  Romantic  -->
                        <LinearLayout android:id="@+id/mood_romantic" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginStart="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🥰" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Romantis" android:textColor="@color/text_dark" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                    <!--  Mood Grid - Row 3  -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <!--  Tired  -->
                        <LinearLayout android:id="@+id/mood_tired" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginEnd="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😴" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lelah" android:textColor="@color/text_dark" android:textSize="12sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!--  Energetic  -->
                        <LinearLayout android:id="@+id/mood_energetic" android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_mood_item" android:layout_marginStart="5dp" android:layout_marginEnd="5dp" android:padding="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="34sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bersemangat" android:textColor="@color/text_dark" android:textSize="11sp" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <!--  Spacer  -->
                        <View android:layout_width="0dp" android:layout_height="90dp" android:layout_weight="1" android:layout_marginStart="5dp"/>
                    </LinearLayout>
                    <!--  Selected Mood Preview  -->
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FFF0F5" android:layout_marginTop="16dp" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:id="@+id/layout_selected_mood" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_card_white" android:padding="12dp" android:visibility="gone">
                        <TextView android:id="@+id/tv_selected_mood_emoji" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="😊" android:textSize="28sp" android:layout_marginEnd="10dp"/>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mood dipilih" android:textColor="@color/text_light" android:textSize="11sp"/>
                            <TextView android:id="@+id/tv_selected_mood_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Bahagia" android:textColor="@color/pink_600" android:textSize="15sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="@color/pink_600" android:textSize="20sp" android:fontFamily="sans-serif-bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!--  Energy Level Card  -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="20dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                        <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_card_pink_gradient">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡" android:textSize="16sp" android:layout_gravity="center"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Level Energi" android:textColor="@color/text_dark" android:textSize="16sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                    <SeekBar android:id="@+id/seekbar_energy" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="10" android:progress="5" android:progressTint="@color/pink_500" android:thumbTint="@color/pink_600" android:progressBackgroundTint="@color/pink_200"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="😩 Sangat Lelah" android:textColor="@color/text_light" android:textSize="11sp"/>
                        <TextView android:id="@+id/tv_energy_value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5/10" android:textColor="@color/pink_600" android:textSize="13sp" android:fontFamily="sans-serif-bold"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="⚡ Full Energi" android:textColor="@color/text_light" android:textSize="11sp" android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!--  Notes Card  -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp" app:cardCornerRadius="20dp" app:cardElevation="4dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <FrameLayout android:layout_width="32dp" android:layout_height="32dp" android:background="@drawable/bg_card_pink_gradient">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="16sp" android:layout_gravity="center"/>
                        </FrameLayout>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Catatan Perasaan" android:textColor="@color/text_dark" android:textSize="16sp" android:fontFamily="sans-serif-medium" android:layout_marginStart="10dp"/>
                    </LinearLayout>
                    <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/RonaBulan.TextInputLayout">
                        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_mood_note" android:layout_width="match_parent" android:layout_height="90dp" android:hint="Ceritakan perasaanmu hari ini..." android:textSize="14sp" android:textColor="@color/text_dark" android:gravity="top" android:inputType="textMultiLine" android:minLines="3"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!--  Save Button  -->
            <Button android:id="@+id/btn_save_mood" android:layout_width="match_parent" android:layout_height="56dp" android:text="💕 Simpan Mood" android:textColor="#FFFFFF" android:textSize="16sp" android:fontFamily="sans-serif-medium" android:background="@drawable/bg_button_pink" android:stateListAnimator="@null" android:elevation="6dp" android:layout_marginBottom="30dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>